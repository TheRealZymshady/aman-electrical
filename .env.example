PORT=8765
NODE_ENV=development

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=replace-with-64-char-hex-secret
# Admin dashboard: /admin.html (Bearer token = this key)
ADMIN_API_KEY=replace-with-strong-admin-key

WHATSAPP_NUMBER=601128731020
BUSINESS_NAME=Aman Electrical

# --- WhatsApp Cloud API (Meta Business) ---
# Create app at https://developers.facebook.com → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_TOKEN=
WHATSAPP_API_VERSION=v21.0

# Comma-separated team numbers that receive new-booking alerts
WHATSAPP_NOTIFY_NUMBERS=601128731020,601162021508,60187664947

# Optional approved templates (recommended for production)
# new_repair_booking body: {{1}} ticket, {{2}} name, {{3}} phone, {{4}} appliance, {{5}} date, {{6}} time, {{7}} issue
WHATSAPP_TEMPLATE_NEW_BOOKING=
# booking_status_update body: {{1}} name, {{2}} ticket, {{3}} status, {{4}} appliance, {{5}} date
WHATSAPP_TEMPLATE_STATUS_UPDATE=

# --- Technician calendar automation ---
# One-time subscribe URL for auto-syncing all repair jobs to phone calendars
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CALENDAR_FEED_TOKEN=

# Optional: auto-create Google Calendar events on every new booking
# Share your calendar with the service account email (Editor access)
GOOGLE_CALENDAR_ID=
# Paste full service account JSON on one line, or set in Render dashboard
GOOGLE_SERVICE_ACCOUNT_JSON=
